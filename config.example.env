# Optional local paths
PODCAST_TRACKER_DATA_DIR=./data
PODCAST_TRACKER_DOCS_DIR=./podcast-docs
PODCAST_TRACKER_PRIVATE_DIR=~/.podcast_tracker_private

# ASR backend: funasr (default), whisper, or openai
PODCAST_TRACKER_ASR_BACKEND=funasr

# Codex CLI is used to convert verbatim transcripts into readable transcripts.
# Leave empty to auto-detect `codex` on PATH.
PODCAST_TRACKER_CODEX_BIN=

# Optional Feishu/Lark publishing. Disabled unless this is set to 1.
PODCAST_TRACKER_ENABLE_LARK=0
PODCAST_TRACKER_LARK_CLI_BIN=
PODCAST_TRACKER_LARK_FOLDER_NAME=Podcast Transcripts
PODCAST_TRACKER_LARK_CHAT_NAME=
PODCAST_TRACKER_LARK_MESSAGE_SEND_AS=bot
PODCAST_TRACKER_LARK_CHAT_DOC_PERM=edit

# Optional OpenAI backend
OPENAI_API_KEY=
